{
  "name": "microbloom-ventures",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:frontend dev:server",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:server": "npm --workspace server run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "build": "npm-run-all build:server build:frontend",
    "build:frontend": "npm --workspace apps/frontend run build",
    "build:server": "npm --workspace server run build",
    "lint": "npm-run-all lint:frontend lint:server",
    "lint:frontend": "npm --workspace apps/frontend run lint",
    "lint:server": "npm --workspace server run lint",
    "migrate": "npx prisma migrate dev",
    "seed": "npx ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.11.6",
    "@types/swagger-ui-express": "^4.1.6",
    "npm-run-all": "^4.1.5",
    "prisma": "^5.19.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "pg": "^8.11.3",
    "slugify": "^1.6.9"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node prisma/seed.ts"
  },
  "overrides": {
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "react": "18.3.1",
    "styled-jsx": {
      "react": "18.3.1"
    }
  }
}
