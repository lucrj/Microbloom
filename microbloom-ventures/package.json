{
  "name": "microbloom-ventures",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "server"
  ],
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "npm-run-all -p dev:frontend dev:server",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:server": "npm --workspace server run dev",

    "build": "npm-run-all build:frontend build:server",
    "build:frontend": "npm --workspace apps/frontend run build",
    "build:server": "npm --workspace server run build",

    "lint": "npm-run-all lint:frontend lint:server",
    "lint:frontend": "npm --workspace apps/frontend run lint",
    "lint:server": "npm --workspace server run lint",

    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "pg": "^8.21.0",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "npm-run-all": "^4.1.5",
    "prisma": "^5.22.0",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "styled-jsx": {
      "react": "19.1.1"
    }
  }
}